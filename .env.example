R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_PRODUCTS=bee-products
R2_BUCKET_KYC=bee-kyc-private
R2_PUBLIC_URL=https://cdn.bee.cm

# ──────────────────────────────────────────────
# Maps
