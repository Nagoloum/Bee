# ──────────────────────────────────────────────
# Environnement
# ──────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
API_PORT=3001
WEB_PORT=3000

# ──────────────────────────────────────────────
# Database (PostgreSQL 16 + extensions)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://bee:bee@localhost:5432/bee?schema=public
DIRECT_URL=postgresql://bee:bee@localhost:5432/bee?schema=public

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=change_me_generate_with_openssl_rand_base64_64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
ENCRYPTION_KEY=change_me_32_bytes_hex

# ──────────────────────────────────────────────
# Admin pré-créé
# ──────────────────────────────────────────────
ADMIN_EMAIL=admin@bee.cm
ADMIN_INITIAL_PASSWORD=ChangeMe_At_First_Login!2026

# ──────────────────────────────────────────────
# Paiement
# ──────────────────────────────────────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET=
NOTCHPAY_API_KEY=

# ──────────────────────────────────────────────
# KYC
# ──────────────────────────────────────────────
SMILE_IDENTITY_PARTNER_ID=
SMILE_IDENTITY_API_KEY=

# ──────────────────────────────────────────────
# SMS / Email
# ──────────────────────────────────────────────
NEXAH_API_KEY=
NEXAH_SENDER_ID=BEE
TWILIO_SID=
TWILIO_AUTH_TOKEN=
RESEND_API_KEY=

# ──────────────────────────────────────────────
# Storage (Cloudflare R2)
