{
  "name": "bee",
  "version": "0.1.0",
  "private": true,
  "description": "Bee Marketplace - E-commerce multi-vendeurs Cameroun",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "db:migrate": "npm run prisma:migrate -w @bee/api",
    "db:seed": "npm run db:seed -w @bee/api",
    "db:studio": "npm run prisma:studio -w @bee/api",
    "db:sql": "npm run db:sql -w @bee/api",
    "docker:up": "docker compose -f infra/docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.dev.yml down",
    "docker:logs": "docker compose -f infra/docker/docker-compose.dev.yml logs -f",
    "api:dev": "npm run dev -w @bee/api",
    "web:dev": "npm run dev -w @bee/web",
    "mobile:dev": "npm run dev -w @bee/mobile"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
