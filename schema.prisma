  auctions              Auction[]
  liveProducts          LiveSessionProduct[]
  negotiations          PriceNegotiation[]
  storyLinks            Story[]

  @@unique([shopId, slug])
  @@index([shopId, status])
  @@index([status, publishedAt(sort: Desc)])
  @@index([ratingAvg(sort: Desc), saleCount(sort: Desc)])
  @@map("products")
}

model ProductVariant {
  id                    String    @id @default(uuid(7)) @db.Uuid
  productId             String    @map("product_id") @db.Uuid
  sku                   String    @unique @db.VarChar(64)
