/// orders est PARTITIONED BY RANGE (created_at) mensuelle — géré via SQL brut.
model Order {
  id                    String            @id @default(uuid(7)) @db.Uuid
  orderNumber           String            @unique @map("order_number") @db.VarChar(20)
  clientId              String            @map("client_id") @db.Uuid
  status                OrderStatus       @default(PENDING)
  subtotalXaf           BigInt            @map("subtotal_xaf")
  discountXaf           BigInt            @default(0) @map("discount_xaf")
  couponId              String?           @map("coupon_id") @db.Uuid
  cashbackUsedXaf       BigInt            @default(0) @map("cashback_used_xaf")
  pointsUsed            Int               @default(0) @map("points_used")
  deliveryFeeXaf        BigInt            @default(0) @map("delivery_fee_xaf")
  totalXaf              BigInt            @map("total_xaf")
  cashbackEarnedXaf     BigInt            @default(0) @map("cashback_earned_xaf")
  pointsEarned          Int               @default(0) @map("points_earned")
  paymentMethod         PaymentMethod     @map("payment_method")
  paymentStatus         PaymentStatus     @default(PENDING) @map("payment_status")
  isInstallment         Boolean           @default(false) @map("is_installment")
  installmentPlan       Int?              @map("installment_plan")
  deliveryMethod        DeliveryMethod    @map("delivery_method")
  deliveryAddressId     String?           @map("delivery_address_id") @db.Uuid
  billingAddressId      String?           @map("billing_address_id") @db.Uuid
  notes                 String?
  placedAt              DateTime?         @map("placed_at") @db.Timestamptz
  confirmedAt           DateTime?         @map("confirmed_at") @db.Timestamptz
  cancelledAt           DateTime?         @map("cancelled_at") @db.Timestamptz
  cancelReason          String?           @map("cancel_reason")
  deliveredAt           DateTime?         @map("delivered_at") @db.Timestamptz
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  client                User              @relation(fields: [clientId], references: [id])
  coupon                Coupon?           @relation(fields: [couponId], references: [id])
  deliveryAddress       Address?          @relation("OrderShippingAddr", fields: [deliveryAddressId], references: [id])
  billingAddress        Address?          @relation("OrderBillingAddr", fields: [billingAddressId], references: [id])

  items                 OrderItem[]
  statusEvents          OrderStatusEvent[]
  payments              OrderPayment[]
  installments          OrderInstallment[]
  delivery              Delivery?
  escrowHolds           EscrowHold[]
  couponRedemptions     CouponRedemption[]
  disputes              Dispute[]

  @@index([clientId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id                 String          @id @default(uuid(7)) @db.Uuid
  orderId            String          @map("order_id") @db.Uuid
  shopId             String          @map("shop_id") @db.Uuid
  variantId          String          @map("variant_id") @db.Uuid
  productSnapshot    Json            @map("product_snapshot")
  quantity           Int
  unitPriceXaf       BigInt          @map("unit_price_xaf")
  subtotalXaf        BigInt          @map("subtotal_xaf")
  commissionBps      Int             @map("commission_bps")
  commissionXaf      BigInt          @map("commission_xaf")
  itemStatus         ItemStatus      @default(PENDING) @map("item_status")
  refusedReason      String?         @map("refused_reason")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  order              Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop            @relation(fields: [shopId], references: [id])
  variant            ProductVariant  @relation(fields: [variantId], references: [id])
  reviews            Review[]

  @@index([orderId])
  @@index([shopId, createdAt(sort: Desc)])
  @@map("order_items")
}

/// order_status_events — PARTITIONED BY RANGE (created_at)
model OrderStatusEvent {
  id          String       @id @default(uuid(7)) @db.Uuid
  orderId     String       @map("order_id") @db.Uuid
  fromStatus  OrderStatus? @map("from_status")
  toStatus    OrderStatus  @map("to_status")
  actorId     String?      @map("actor_id") @db.Uuid
  actorRole   UserRole?    @map("actor_role")
  reason      String?
  metadata    Json?
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt(sort: Desc)])
  @@map("order_status_events")
}

model OrderPayment {
  id                 String         @id @default(uuid(7)) @db.Uuid
  orderId            String         @map("order_id") @db.Uuid
  provider           String         @db.VarChar(40)
  providerRef        String?        @map("provider_ref") @db.VarChar(120)
  amountXaf          BigInt         @map("amount_xaf")
  method             PaymentMethod
  status             PaymentStatus  @default(PENDING)
  paidAt             DateTime?      @map("paid_at") @db.Timestamptz
  failureReason      String?        @map("failure_reason")
  rawResponse        Json?          @map("raw_response")
  idempotencyKey     String         @unique @map("idempotency_key") @db.VarChar(120)
  webhookReceived    Boolean        @default(false) @map("webhook_received")
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  order              Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([providerRef])
  @@index([status])
  @@map("order_payments")
}

model OrderInstallment {
  id                 String              @id @default(uuid(7)) @db.Uuid
  orderId            String              @map("order_id") @db.Uuid
  sequence           Int
  amountXaf          BigInt              @map("amount_xaf")
  dueDate            DateTime            @map("due_date") @db.Date
  paidAt             DateTime?           @map("paid_at") @db.Timestamptz
  status             InstallmentStatus   @default(PENDING)
  reminderCount      Int                 @default(0) @map("reminder_count")
  lastReminderAt     DateTime?           @map("last_reminder_at") @db.Timestamptz
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, sequence])
  @@index([status, dueDate])
  @@map("order_installments")
}

model PriceNegotiation {
  id                   String              @id @default(uuid(7)) @db.Uuid
  productId            String              @map("product_id") @db.Uuid
  variantId            String              @map("variant_id") @db.Uuid
  clientId             String              @map("client_id") @db.Uuid
  shopId               String              @map("shop_id") @db.Uuid
  proposedPriceXaf     BigInt              @map("proposed_price_xaf")
  shopMinPriceXaf      BigInt              @map("shop_min_price_xaf")
  status               NegotiationStatus   @default(PENDING)
  lockedUntil          DateTime?           @map("locked_until") @db.Timestamptz
  rejectionReason      String?             @map("rejection_reason")
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  product              Product             @relation(fields: [productId], references: [id])
  variant              ProductVariant      @relation(fields: [variantId], references: [id])
  client               User                @relation(fields: [clientId], references: [id])
  shop                 Shop                @relation(fields: [shopId], references: [id])

  cartItems            CartItem[]

  @@index([clientId, status])
  @@index([lockedUntil])
  @@map("price_negotiations")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 8 — LIVRAISONS
// ═══════════════════════════════════════════════════════════════════

model Delivery {
  id                     String          @id @default(uuid(7)) @db.Uuid
  orderId                String          @unique @map("order_id") @db.Uuid
  deliveryId             String?         @map("delivery_id") @db.Uuid
  shopId                 String          @map("shop_id") @db.Uuid
  type                   DeliveryType
  pickupAddressId        String          @map("pickup_address_id") @db.Uuid
  dropoffAddressId       String          @map("dropoff_address_id") @db.Uuid
  distanceKm             Decimal?        @map("distance_km") @db.Decimal(6, 2)
  estimatedDurationMin   Int?            @map("estimated_duration_min")
  feeXaf                 BigInt          @map("fee_xaf")
  deliveryEarningXaf     BigInt          @map("delivery_earning_xaf")
  status                 DeliveryStatus  @default(PENDING)
  assignedAt             DateTime?       @map("assigned_at") @db.Timestamptz
  acceptedAt             DateTime?       @map("accepted_at") @db.Timestamptz
  pickedUpAt             DateTime?       @map("picked_up_at") @db.Timestamptz
  deliveredAt            DateTime?       @map("delivered_at") @db.Timestamptz
  failedReason           String?         @map("failed_reason")
  proofPhotoUrl          String?         @map("proof_photo_url")
  signatureUrl           String?         @map("signature_url")
  clientRating           Int?            @map("client_rating")
  clientComment          String?         @map("client_comment")
  createdAt              DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  order                  Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryDriver         User?           @relation("DeliveryDriver", fields: [deliveryId], references: [id])
  shop                   Shop            @relation(fields: [shopId], references: [id])
  pickupAddress          Address         @relation("DeliveryPickup", fields: [pickupAddressId], references: [id])
  dropoffAddress         Address         @relation("DeliveryDropoff", fields: [dropoffAddressId], references: [id])

  trackingEvents         DeliveryTrackingEvent[]

  @@index([deliveryId, status])
  @@index([shopId, createdAt(sort: Desc)])
  @@index([status])
  @@map("deliveries")
}

/// delivery_tracking_events — PARTITIONED BY RANGE (recorded_at)
model DeliveryTrackingEvent {
  id            String              @id @default(uuid(7)) @db.Uuid
  deliveryId    String              @map("delivery_id") @db.Uuid
  location      Unsupported("geography(Point, 4326)")?
