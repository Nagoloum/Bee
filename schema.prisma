model Wallet {
  id                      String              @id @default(uuid(7)) @db.Uuid
  userId                  String              @unique @map("user_id") @db.Uuid
  type                    WalletType
  currency                String              @default("XAF") @db.Char(3)
  balanceAvailableXaf     BigInt              @default(0) @map("balance_available_xaf")
  balancePendingXaf       BigInt              @default(0) @map("balance_pending_xaf")
