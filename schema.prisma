model Badge {
  id            String      @id @default(uuid(7)) @db.Uuid
  slug          String      @unique @db.VarChar(40)
  name          String      @db.VarChar(80)
  description   String?
  iconUrl       String?     @map("icon_url")
  criteria      Json        @default("{}")
  targetRole    UserRole?   @map("target_role")
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  users         UserBadge[]

  @@map("badges")
}

model UserBadge {
  userId      String    @map("user_id") @db.Uuid
  badgeId     String    @map("badge_id") @db.Uuid
  earnedAt    DateTime  @default(now()) @map("earned_at") @db.Timestamptz

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge       Badge     @relation(fields: [badgeId], references: [id])

  @@id([userId, badgeId])
  @@map("user_badges")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 17 — RECRUTEMENT
// ═══════════════════════════════════════════════════════════════════

model JobOffer {
  id                 String              @id @default(uuid(7)) @db.Uuid
  shopId             String              @map("shop_id") @db.Uuid
  title              String              @db.VarChar(160)
  description        String
  type               JobType
  location           String?             @db.VarChar(160)
  isRemote           Boolean             @default(false) @map("is_remote")
  salaryMinXaf       BigInt?             @map("salary_min_xaf")
  salaryMaxXaf       BigInt?             @map("salary_max_xaf")
  requirements       String?
  benefits           String?
  status             JobStatus           @default(DRAFT)
  publishedAt        DateTime?           @map("published_at") @db.Timestamptz
  expiresAt          DateTime?           @map("expires_at") @db.Timestamptz
  applicationCount   Int                 @default(0) @map("application_count")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  shop               Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  applications       JobApplication[]

  @@index([shopId, status])
  @@index([status, publishedAt])
  @@map("job_offers")
}

model JobApplication {
  id              String              @id @default(uuid(7)) @db.Uuid
  jobOfferId      String              @map("job_offer_id") @db.Uuid
  applicantId     String              @map("applicant_id") @db.Uuid
  cvUrl           String?             @map("cv_url")
  coverLetter     String?             @map("cover_letter")
  linkedinUrl     String?             @map("linkedin_url")
  status          ApplicationStatus   @default(SUBMITTED)
  vendorNotes     String?             @map("vendor_notes")
  appliedAt       DateTime            @default(now()) @map("applied_at") @db.Timestamptz
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  jobOffer        JobOffer            @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)
  applicant       User                @relation(fields: [applicantId], references: [id])

  @@unique([jobOfferId, applicantId])
  @@index([applicantId, appliedAt(sort: Desc)])
  @@map("job_applications")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 18 — ADMIN CMS
// ═══════════════════════════════════════════════════════════════════

model SiteSetting {
  id             String    @id @default(uuid(7)) @db.Uuid
  key            String    @unique @db.VarChar(80)
  value          Json
  category       String?   @db.VarChar(40)
  description    String?
  isPublic       Boolean   @default(false) @map("is_public")
  updatedById    String?   @map("updated_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  updatedBy      User?     @relation(fields: [updatedById], references: [id])

  @@map("site_settings")
}

model Banner {
  id                   String           @id @default(uuid(7)) @db.Uuid
  title                String?          @db.VarChar(160)
  subtitle             String?          @db.VarChar(240)
  imageUrl             String           @map("image_url")
  imageMobileUrl       String?          @map("image_mobile_url")
  linkUrl              String?          @map("link_url")
  ctaLabel             String?          @map("cta_label") @db.VarChar(60)
  position             BannerPosition
  targetAudience       Json             @default("{}") @map("target_audience")
  startsAt             DateTime?        @map("starts_at") @db.Timestamptz
  endsAt               DateTime?        @map("ends_at") @db.Timestamptz
  displayOrder         Int              @default(0) @map("display_order")
  isActive             Boolean          @default(true) @map("is_active")
  clickCount           Int              @default(0) @map("click_count")
  impressionCount      Int              @default(0) @map("impression_count")
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@index([position, isActive, displayOrder])
  @@map("banners")
}

model LegalDocument {
  id                    String                  @id @default(uuid(7)) @db.Uuid
  slug                  String                  @db.VarChar(40)
  language              String                  @db.Char(2)
  title                 String                  @db.VarChar(200)
  contentMd             String                  @map("content_md")
  version               String                  @db.VarChar(20)
  publishedAt           DateTime?               @map("published_at") @db.Timestamptz
  isCurrent             Boolean                 @default(false) @map("is_current")
  requiresAcceptance    Boolean                 @default(false) @map("requires_acceptance")
  createdAt             DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  acceptances           UserLegalAcceptance[]

  @@unique([slug, language, version])
  @@index([slug, language, isCurrent])
  @@map("legal_documents")
}

model UserLegalAcceptance {
  id               String          @id @default(uuid(7)) @db.Uuid
  userId           String          @map("user_id") @db.Uuid
  legalDocId       String          @map("legal_doc_id") @db.Uuid
  acceptedAt       DateTime        @default(now()) @map("accepted_at") @db.Timestamptz
  ip               String?         @db.Inet
  userAgent        String?         @map("user_agent")

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalDoc         LegalDocument   @relation(fields: [legalDocId], references: [id])

  @@unique([userId, legalDocId])
  @@map("user_legal_acceptances")
}

model FooterLink {
  id              String      @id @default(uuid(7)) @db.Uuid
  labelFr         String      @map("label_fr") @db.VarChar(80)
  labelEn         String?     @map("label_en") @db.VarChar(80)
  url             String
  columnKey       String      @map("column_key") @db.VarChar(40)
  displayOrder    Int         @default(0) @map("display_order")
  isExternal      Boolean     @default(false) @map("is_external")
  icon            String?     @db.VarChar(40)
  isActive        Boolean     @default(true) @map("is_active")
  visibleToRole   UserRole?   @map("visible_to_role")

  @@index([columnKey, displayOrder])
  @@map("footer_links")
}

model HomepageSection {
  id             String               @id @default(uuid(7)) @db.Uuid
  type           HomepageSectionType
  titleFr        String?              @map("title_fr") @db.VarChar(160)
  titleEn        String?              @map("title_en") @db.VarChar(160)
  config         Json                 @default("{}")
  displayOrder   Int                  @default(0) @map("display_order")
  isActive       Boolean              @default(true) @map("is_active")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  @@map("homepage_sections")
}

model AnnouncementBar {
  id              String              @id @default(uuid(7)) @db.Uuid
  messageFr       String              @map("message_fr")
  messageEn       String?             @map("message_en")
  type            AnnouncementType    @default(INFO)
  linkUrl         String?             @map("link_url")
  bgColor         String?             @map("bg_color") @db.VarChar(20)
  startsAt        DateTime?           @map("starts_at") @db.Timestamptz
  endsAt          DateTime?           @map("ends_at") @db.Timestamptz
  isActive        Boolean             @default(true) @map("is_active")
  dismissible     Boolean             @default(true)

  @@map("announcement_bars")
}

model FeatureFlag {
  id            String    @id @default(uuid(7)) @db.Uuid
  key           String    @unique @db.VarChar(60)
  isEnabled     Boolean   @default(false) @map("is_enabled")
  rolloutPct    Int       @default(0) @map("rollout_pct")
  audience      Json      @default("{}")
  description   String?
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("feature_flags")
}

model EmailTemplate {
  id            String    @id @default(uuid(7)) @db.Uuid
  slug          String    @unique @db.VarChar(60)
  subjectFr     String    @map("subject_fr") @db.VarChar(240)
  subjectEn     String?   @map("subject_en") @db.VarChar(240)
  bodyMjmlFr    String    @map("body_mjml_fr")
  bodyMjmlEn    String?   @map("body_mjml_en")
  variables     Json      @default("[]")
  isActive      Boolean   @default(true) @map("is_active")
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("email_templates")
}

model NotificationTemplate {
  id          String               @id @default(uuid(7)) @db.Uuid
  slug        String               @db.VarChar(60)
  channel     NotificationChannel
  titleFr     String               @map("title_fr") @db.VarChar(120)
  titleEn     String?              @map("title_en") @db.VarChar(120)
  bodyFr      String               @map("body_fr")
  bodyEn      String?              @map("body_en")
  variables   Json                 @default("[]")
  actionUrl   String?              @map("action_url")
  isActive    Boolean              @default(true) @map("is_active")
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([slug, channel])
  @@map("notification_templates")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 19 — NOTIFICATIONS
// ═══════════════════════════════════════════════════════════════════

/// notifications — PARTITIONED BY RANGE (created_at) mensuelle
model Notification {
  id             String              @id @default(uuid(7)) @db.Uuid
  userId         String              @map("user_id") @db.Uuid
  type           NotificationType
  title          String              @db.VarChar(200)
  body           String?
  data           Json?
  iconUrl        String?             @map("icon_url")
  readAt         DateTime?           @map("read_at") @db.Timestamptz
  actionTaken    Boolean             @default(false) @map("action_taken")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

model PushToken {
  id             String        @id @default(uuid(7)) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  token          String        @unique
  platform       PushPlatform
  deviceId       String?       @map("device_id") @db.VarChar(80)
  appVersion     String?       @map("app_version") @db.VarChar(20)
  isActive       Boolean       @default(true) @map("is_active")
  lastUsedAt     DateTime?     @map("last_used_at") @db.Timestamptz
  failureCount   Int           @default(0) @map("failure_count")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 20 — MESSAGING
// ═══════════════════════════════════════════════════════════════════

model Conversation {
  id                 String                  @id @default(uuid(7)) @db.Uuid
  type               ConversationType
  status             ConversationStatus      @default(OPEN)
  subject            String?                 @db.VarChar(240)
  participantIds     String[]                @map("participant_ids") @db.Uuid
  assignedAdminId    String?                 @map("assigned_admin_id") @db.Uuid
  priority           ConversationPriority    @default(NORMAL)
  lastMessageAt      DateTime?               @map("last_message_at") @db.Timestamptz
  metadata           Json?
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  assignedAdmin      User?                   @relation("ConversationAssigned", fields: [assignedAdminId], references: [id])
  messages           Message[]

  @@index([type, status])
  @@map("conversations")
}

/// messages — PARTITIONED BY RANGE (created_at)
model Message {
  id                String         @id @default(uuid(7)) @db.Uuid
  conversationId    String         @map("conversation_id") @db.Uuid
  senderType        SenderType     @map("sender_type")
  senderId          String?        @map("sender_id") @db.Uuid
  body              String
  attachments       Json           @default("[]")
  readBy            String[]       @map("read_by") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz

  conversation      Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 21 — SÉCURITÉ & OPS
// ═══════════════════════════════════════════════════════════════════

/// audit_logs — PARTITIONED BY RANGE (created_at) mensuelle
model AuditLog {
  id             String       @id @default(uuid(7)) @db.Uuid
  actorId        String?      @map("actor_id") @db.Uuid
  actorRole      UserRole?    @map("actor_role")
  action         String       @db.VarChar(80)
  entityType     String?      @map("entity_type") @db.VarChar(60)
  entityId       String?      @map("entity_id") @db.Uuid
  changes        Json?
  ip             String?      @db.Inet
  userAgent      String?      @map("user_agent")
  requestId      String?      @map("request_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  actor          User?        @relation(fields: [actorId], references: [id])

  @@index([actorId, createdAt(sort: Desc)])
  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model OutboxEvent {
  id                 String      @id @default(uuid(7)) @db.Uuid
  aggregateType      String      @map("aggregate_type") @db.VarChar(60)
  aggregateId        String      @map("aggregate_id") @db.Uuid
  eventType          String      @map("event_type") @db.VarChar(80)
  payload            Json
  processedAt        DateTime?   @map("processed_at") @db.Timestamptz
  retryCount         Int         @default(0) @map("retry_count")
  nextRetryAt        DateTime?   @map("next_retry_at") @db.Timestamptz
  lastError          String?     @map("last_error")
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz

  @@index([processedAt, nextRetryAt])
  @@map("outbox_events")
}

model IdempotencyKey {
  key         String    @id @db.VarChar(120)
  userId      String?   @map("user_id") @db.Uuid
  endpoint    String?   @db.VarChar(120)
  response    Json?
  statusCode  Int?      @map("status_code")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([expiresAt])
  @@map("idempotency_keys")
}

model WebhookDelivery {
  id                 String          @id @default(uuid(7)) @db.Uuid
  provider           String          @db.VarChar(40)
  event              String          @db.VarChar(80)
  externalId         String?         @map("external_id") @db.VarChar(120)
  payload            Json
  signatureValid     Boolean?        @map("signature_valid")
  status             WebhookStatus   @default(RECEIVED)
  attempts           Int             @default(0)
  lastError          String?         @map("last_error")
  receivedAt         DateTime        @default(now()) @map("received_at") @db.Timestamptz
  processedAt        DateTime?       @map("processed_at") @db.Timestamptz

  @@index([provider, externalId])
  @@index([status, receivedAt])
  @@map("webhook_deliveries")
}

model RateLimitBucket {
  key         String    @id @db.VarChar(120)
  count       Int       @default(0)
  resetAt     DateTime  @map("reset_at") @db.Timestamptz

  @@index([resetAt])
  @@map("rate_limit_buckets")
}
