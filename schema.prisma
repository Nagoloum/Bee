  brandId        String?   @map("brand_id") @db.Uuid
  name           String    @db.VarChar(240)
  description    String?
  defaultImages  Json      @default("[]") @map("default_images")
  specs          Json      @default("{}")
  isActive       Boolean   @default(true) @map("is_active")
  searchVector   Unsupported("tsvector")?  @map("search_vector")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  category       Category? @relation(fields: [categoryId], references: [id])
  brand          Brand?    @relation(fields: [brandId], references: [id])
  products       Product[]

  @@index([categoryId])
  @@map("official_products")
}

model Product {
  id                    String             @id @default(uuid(7)) @db.Uuid
  shopId                String             @map("shop_id") @db.Uuid
  officialProductId     String?            @map("official_product_id") @db.Uuid
  slug                  String             @db.VarChar(160)
  name                  String             @db.VarChar(240)
  description           String?
  basePriceXaf          BigInt             @map("base_price_xaf")
  compareAtPriceXaf     BigInt?            @map("compare_at_price_xaf")
  currency              String             @default("XAF") @db.Char(3)
  hasVariants           Boolean            @default(false) @map("has_variants")
  status                ProductStatus      @default(DRAFT)
  visibility            ProductVisibility  @default(PUBLIC)
  stockTracking         Boolean            @default(true) @map("stock_tracking")
  totalStock            Int?               @map("total_stock")
  negotiationEnabled    Boolean            @default(false) @map("negotiation_enabled")
  negotiationMinXaf     BigInt?            @map("negotiation_min_xaf")
  costPriceXaf          BigInt?            @map("cost_price_xaf")
  weightGrams           Int?               @map("weight_grams")
  dimensionsCm          Json?              @map("dimensions_cm")
  ratingAvg             Decimal            @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount           Int                @default(0) @map("rating_count")
  viewCount             BigInt             @default(0) @map("view_count")
  saleCount             Int                @default(0) @map("sale_count")
  wishlistCount         Int                @default(0) @map("wishlist_count")
  tags                  String[]
  publishedAt           DateTime?          @map("published_at") @db.Timestamptz
  searchVector          Unsupported("tsvector")?  @map("search_vector")
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?          @map("deleted_at") @db.Timestamptz

  shop                  Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
