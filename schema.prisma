/// wallet_transactions — PARTITIONED BY RANGE (created_at) mensuelle
model WalletTransaction {
  id                  String              @id @default(uuid(7)) @db.Uuid
  walletId            String              @map("wallet_id") @db.Uuid
  type                WalletTxType
  direction           WalletTxDirection
  amountXaf           BigInt              @map("amount_xaf")
  balanceAfterXaf     BigInt              @map("balance_after_xaf")
  refType             String?             @map("ref_type") @db.VarChar(40)
  refId               String?             @map("ref_id") @db.Uuid
  description         String?
  metadata            Json?
  idempotencyKey      String              @unique @map("idempotency_key") @db.VarChar(120)
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz

  wallet              Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)
  releasedEscrow      EscrowHold?         @relation("EscrowReleasedTx")

  @@index([walletId, createdAt(sort: Desc)])
  @@index([refType, refId])
  @@map("wallet_transactions")
}

model EscrowHold {
  id                    String              @id @default(uuid(7)) @db.Uuid
  orderId               String              @map("order_id") @db.Uuid
  vendorWalletId        String              @map("vendor_wallet_id") @db.Uuid
  shopId                String              @map("shop_id") @db.Uuid
  amountXaf             BigInt              @map("amount_xaf")
  status                EscrowStatus        @default(HELD)
  heldAt                DateTime            @default(now()) @map("held_at") @db.Timestamptz
  releaseScheduledAt    DateTime?           @map("release_scheduled_at") @db.Timestamptz
  releasedAt            DateTime?           @map("released_at") @db.Timestamptz
  releasedTxId          String?             @unique @map("released_tx_id") @db.Uuid
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  order                 Order               @relation(fields: [orderId], references: [id])
  vendorWallet          Wallet              @relation(fields: [vendorWalletId], references: [id])
  shop                  Shop                @relation("ShopEscrow", fields: [shopId], references: [id])
  releasedTx            WalletTransaction?  @relation("EscrowReleasedTx", fields: [releasedTxId], references: [id])

  @@index([status, releaseScheduledAt])
  @@index([orderId])
  @@map("escrow_holds")
}

model WithdrawalRequest {
  id                  String              @id @default(uuid(7)) @db.Uuid
  walletId            String              @map("wallet_id") @db.Uuid
  amountXaf           BigInt              @map("amount_xaf")
  feeXaf              BigInt              @default(0) @map("fee_xaf")
  netAmountXaf        BigInt              @map("net_amount_xaf")
  method              PayoutMethod
  destinationPhone    String?             @map("destination_phone") @db.VarChar(16)
  destinationAccount  String?             @map("destination_account") @db.VarChar(40)
  status              WithdrawalStatus    @default(PENDING)
  requestedAt         DateTime            @default(now()) @map("requested_at") @db.Timestamptz
  approvedById        String?             @map("approved_by_id") @db.Uuid
  approvedAt          DateTime?           @map("approved_at") @db.Timestamptz
  processedAt         DateTime?           @map("processed_at") @db.Timestamptz
  providerRef         String?             @map("provider_ref") @db.VarChar(120)
  providerResponse    Json?               @map("provider_response")
  rejectionReason     String?             @map("rejection_reason")
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  wallet              Wallet              @relation(fields: [walletId], references: [id])
  approvedBy          User?               @relation("WithdrawalApprovedBy", fields: [approvedById], references: [id])

  @@index([walletId, status])
  @@index([status, requestedAt])
  @@map("withdrawal_requests")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 10 — PROMOTIONS
// ═══════════════════════════════════════════════════════════════════

model Coupon {
  id                    String         @id @default(uuid(7)) @db.Uuid
  shopId                String?        @map("shop_id") @db.Uuid
  code                  String         @unique @db.VarChar(40)
  type                  CouponType
  value                 Int
  minOrderXaf           BigInt?        @map("min_order_xaf")
  maxDiscountXaf        BigInt?        @map("max_discount_xaf")
  usageLimit            Int?           @map("usage_limit")
  usageLimitPerUser     Int            @default(1) @map("usage_limit_per_user")
  usageCount            Int            @default(0) @map("usage_count")
  appliesTo             CouponScope    @default(ALL) @map("applies_to")
  scopeIds              String[]       @map("scope_ids") @db.Uuid
  startsAt              DateTime?      @map("starts_at") @db.Timestamptz
  endsAt                DateTime?      @map("ends_at") @db.Timestamptz
  isAutoGenerated       Boolean        @default(false) @map("is_auto_generated")
  isActive              Boolean        @default(true) @map("is_active")
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  shop                  Shop?          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  redemptions           CouponRedemption[]
  orders                Order[]

  @@index([code])
  @@index([shopId, isActive])
  @@map("coupons")
}

model CouponRedemption {
  id                     String      @id @default(uuid(7)) @db.Uuid
  couponId               String      @map("coupon_id") @db.Uuid
  orderId                String      @map("order_id") @db.Uuid
  userId                 String      @map("user_id") @db.Uuid
  discountAppliedXaf     BigInt      @map("discount_applied_xaf")
  createdAt              DateTime    @default(now()) @map("created_at") @db.Timestamptz

  coupon                 Coupon      @relation(fields: [couponId], references: [id])
  order                  Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user                   User        @relation(fields: [userId], references: [id])

  @@unique([couponId, orderId])
  @@index([userId, couponId])
  @@map("coupon_redemptions")
}

model FlashSale {
  id                     String          @id @default(uuid(7)) @db.Uuid
  shopId                 String          @map("shop_id") @db.Uuid
  name                   String          @db.VarChar(160)
  discountPercentage     Int             @map("discount_percentage")
  startsAt               DateTime        @map("starts_at") @db.Timestamptz
  endsAt                 DateTime        @map("ends_at") @db.Timestamptz
  maxProducts            Int             @default(5) @map("max_products")
  isActive               Boolean         @default(true) @map("is_active")
  notificationSent       Boolean         @default(false) @map("notification_sent")
  createdAt              DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  shop                   Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items                  FlashSaleItem[]

  @@index([shopId, isActive])
  @@index([endsAt])
  @@map("flash_sales")
}

model FlashSaleItem {
  id               String          @id @default(uuid(7)) @db.Uuid
  flashSaleId      String          @map("flash_sale_id") @db.Uuid
  productId        String          @map("product_id") @db.Uuid
  variantId        String          @map("variant_id") @db.Uuid
  originalPrice    BigInt          @map("original_price")
  flashPrice       BigInt          @map("flash_price")
  maxQuantity      Int?            @map("max_quantity")
  soldQuantity     Int             @default(0) @map("sold_quantity")
  maxPerUser       Int             @default(1) @map("max_per_user")

  flashSale        FlashSale       @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product          Product         @relation(fields: [productId], references: [id])
  variant          ProductVariant  @relation(fields: [variantId], references: [id])

  @@map("flash_sale_items")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 11 — ENCHÈRES
// ═══════════════════════════════════════════════════════════════════

model Auction {
  id                      String           @id @default(uuid(7)) @db.Uuid
  shopId                  String           @map("shop_id") @db.Uuid
  productId               String           @map("product_id") @db.Uuid
  variantId               String           @map("variant_id") @db.Uuid
  type                    AuctionType
  startingPriceXaf        BigInt           @map("starting_price_xaf")
  minBidIncrementXaf      BigInt           @default(500) @map("min_bid_increment_xaf")
  reservePriceXaf         BigInt?          @map("reserve_price_xaf")
  currentPriceXaf         BigInt           @map("current_price_xaf")
  currentWinnerId         String?          @map("current_winner_id") @db.Uuid
  bidCount                Int              @default(0) @map("bid_count")
  commissionBps           Int              @default(1000) @map("commission_bps")
  startsAt                DateTime         @map("starts_at") @db.Timestamptz
  endsAt                  DateTime         @map("ends_at") @db.Timestamptz
  status                  AuctionStatus    @default(SCHEDULED)
  winnerId                String?          @map("winner_id") @db.Uuid
  winningBidXaf           BigInt?          @map("winning_bid_xaf")
  createdAt               DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  shop                    Shop             @relation(fields: [shopId], references: [id])
  product                 Product          @relation(fields: [productId], references: [id])
  variant                 ProductVariant   @relation(fields: [variantId], references: [id])
  currentLeader           User?            @relation("AuctionLeader", fields: [currentWinnerId], references: [id])
  winner                  User?            @relation("AuctionWinner", fields: [winnerId], references: [id])
  bids                    AuctionBid[]

  @@index([status, endsAt])
  @@index([shopId, createdAt(sort: Desc)])
  @@map("auctions")
}

/// auction_bids — PARTITIONED BY RANGE (placed_at)
model AuctionBid {
  id           String    @id @default(uuid(7)) @db.Uuid
  auctionId    String    @map("auction_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  amountXaf    BigInt    @map("amount_xaf")
  isAutoBid    Boolean   @default(false) @map("is_auto_bid")
  maxAutoXaf   BigInt?   @map("max_auto_xaf")
  placedAt     DateTime  @default(now()) @map("placed_at") @db.Timestamptz

  auction      Auction   @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id])

  @@index([auctionId, placedAt(sort: Desc)])
  @@index([userId])
  @@map("auction_bids")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 12 — LIVE SHOPPING & STORIES
// ═══════════════════════════════════════════════════════════════════

model LiveSession {
  id               String                @id @default(uuid(7)) @db.Uuid
  shopId           String                @map("shop_id") @db.Uuid
  title            String                @db.VarChar(160)
  description      String?
  thumbnailUrl     String?               @map("thumbnail_url")
  streamKey        String                @unique @map("stream_key") @db.VarChar(64)
  playbackUrl      String?               @map("playback_url")
  recordingUrl     String?               @map("recording_url")
  status           LiveStatus            @default(SCHEDULED)
  scheduledAt      DateTime?             @map("scheduled_at") @db.Timestamptz
  startedAt        DateTime?             @map("started_at") @db.Timestamptz
  endedAt          DateTime?             @map("ended_at") @db.Timestamptz
  peakViewers      Int                   @default(0) @map("peak_viewers")
  totalViews       Int                   @default(0) @map("total_views")
  ordersCount      Int                   @default(0) @map("orders_count")
  revenueXaf       BigInt                @default(0) @map("revenue_xaf")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  shop             Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products         LiveSessionProduct[]

  @@index([shopId, status])
  @@index([status, scheduledAt])
  @@map("live_sessions")
}

model LiveSessionProduct {
  id             String           @id @default(uuid(7)) @db.Uuid
  liveId         String           @map("live_id") @db.Uuid
  productId      String           @map("product_id") @db.Uuid
  variantId      String           @map("variant_id") @db.Uuid
  flashPrice     BigInt?          @map("flash_price")
  featuredAt     DateTime?        @map("featured_at") @db.Timestamptz
  soldDuring     Int              @default(0) @map("sold_during")

  liveSession    LiveSession      @relation(fields: [liveId], references: [id], onDelete: Cascade)
  product        Product          @relation(fields: [productId], references: [id])
  variant        ProductVariant   @relation(fields: [variantId], references: [id])

  @@map("live_session_products")
}

model Story {
  id               String          @id @default(uuid(7)) @db.Uuid
  shopId           String          @map("shop_id") @db.Uuid
  mediaUrl         String          @map("media_url")
  mediaType        StoryMediaType  @map("media_type")
  thumbnailUrl     String?         @map("thumbnail_url")
  caption          String?
  linkProductId    String?         @map("link_product_id") @db.Uuid
  linkUrl          String?         @map("link_url")
  viewsCount       Int             @default(0) @map("views_count")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  expiresAt        DateTime        @map("expires_at") @db.Timestamptz

  shop             Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  linkedProduct    Product?        @relation(fields: [linkProductId], references: [id])
  views            StoryView[]

  @@index([shopId, expiresAt])
  @@index([expiresAt])
  @@map("stories")
}

/// story_views — PARTITIONED BY RANGE (viewed_at), rétention 30j
model StoryView {
  id          String    @id @default(uuid(7)) @db.Uuid
  storyId     String    @map("story_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  viewedAt    DateTime  @default(now()) @map("viewed_at") @db.Timestamptz

  story       Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@map("story_views")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 13 — AVIS
// ═══════════════════════════════════════════════════════════════════

model Review {
  id                String        @id @default(uuid(7)) @db.Uuid
  orderItemId       String        @map("order_item_id") @db.Uuid
  authorId          String        @map("author_id") @db.Uuid
  targetType        ReviewTarget  @map("target_type")
  targetId          String        @map("target_id") @db.Uuid
  rating            Int
  comment           String?
  photos            Json          @default("[]")
  isVerified        Boolean       @default(true) @map("is_verified")
  helpfulCount      Int           @default(0) @map("helpful_count")
  replyBody         String?       @map("reply_body")
  replyAt           DateTime?     @map("reply_at") @db.Timestamptz
  isHidden          Boolean       @default(false) @map("is_hidden")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  orderItem         OrderItem     @relation(fields: [orderItemId], references: [id])
  author            User          @relation(fields: [authorId], references: [id])

  @@unique([orderItemId, targetType])
  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("reviews")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 14 — LITIGES
// ═══════════════════════════════════════════════════════════════════

model Dispute {
  id                 String             @id @default(uuid(7)) @db.Uuid
  orderId            String             @map("order_id") @db.Uuid
  openedById         String             @map("opened_by_id") @db.Uuid
  againstUserId      String             @map("against_user_id") @db.Uuid
  type               DisputeType
  reason             String
  status             DisputeStatus      @default(OPEN)
  aiSuggestion       Json?              @map("ai_suggestion")
  aiAutoResolved     Boolean            @default(false) @map("ai_auto_resolved")
  resolvedById       String?            @map("resolved_by_id") @db.Uuid
  resolvedAt         DateTime?          @map("resolved_at") @db.Timestamptz
  resolutionNotes    String?            @map("resolution_notes")
  refundAmountXaf    BigInt             @default(0) @map("refund_amount_xaf")
  penaltyXaf         BigInt             @default(0) @map("penalty_xaf")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  order              Order              @relation(fields: [orderId], references: [id])
  openedBy           User               @relation("DisputeOpenedBy", fields: [openedById], references: [id])
  againstUser        User               @relation("DisputeAgainst", fields: [againstUserId], references: [id])
  resolvedBy         User?              @relation("DisputeResolvedBy", fields: [resolvedById], references: [id])
  messages           DisputeMessage[]

  @@index([orderId])
  @@index([status, createdAt])
  @@index([againstUserId, createdAt])
  @@map("disputes")
}

model DisputeMessage {
  id           String        @id @default(uuid(7)) @db.Uuid
  disputeId    String        @map("dispute_id") @db.Uuid
  senderId     String        @map("sender_id") @db.Uuid
  senderRole   UserRole      @map("sender_role")
  body         String
  attachments  Json          @default("[]")
  isInternal   Boolean       @default(false) @map("is_internal")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz

  dispute      Dispute       @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sender       User          @relation(fields: [senderId], references: [id])

  @@index([disputeId, createdAt])
  @@map("dispute_messages")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 15 — PARRAINAGE & AFFILIATION
// ═══════════════════════════════════════════════════════════════════

model Referral {
  id              String           @id @default(uuid(7)) @db.Uuid
  referrerId      String           @map("referrer_id") @db.Uuid
  referredId      String           @unique @map("referred_id") @db.Uuid
  code            String           @db.VarChar(20)
  type            ReferralType
  status          ReferralStatus   @default(PENDING)
  rewardType      RewardType?      @map("reward_type")
  rewardValue     BigInt?          @map("reward_value")
  qualifiedAt     DateTime?        @map("qualified_at") @db.Timestamptz
  grantedAt       DateTime?        @map("granted_at") @db.Timestamptz
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz

  @@index([referrerId, status])
  @@map("referrals")
}

model FamilyBadgeInvitation {
  id                String    @id @default(uuid(7)) @db.Uuid
  inviterId         String    @map("inviter_id") @db.Uuid
  inviteeId         String    @map("invitee_id") @db.Uuid
  month             String    @db.Char(7)
  rewardClaimed     Boolean   @default(false) @map("reward_claimed")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  inviter           User      @relation("FamilyInviter", fields: [inviterId], references: [id])
  invitee           User      @relation("FamilyInvitee", fields: [inviteeId], references: [id])

  @@unique([inviterId, inviteeId])
  @@index([inviterId, month])
  @@map("family_badge_invitations")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 16 — GAMIFICATION
// ═══════════════════════════════════════════════════════════════════

model UserPoints {
  userId           String      @id @map("user_id") @db.Uuid
