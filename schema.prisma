// ═══════════════════════════════════════════════════════════════════
// DOMAINE 1 — IDENTITÉ & AUTHENTIFICATION
// ═══════════════════════════════════════════════════════════════════

model User {
  id                 String     @id @default(uuid(7)) @db.Uuid
  email              String     @unique @db.Citext
  phoneE164          String?    @unique @map("phone_e164") @db.VarChar(16)
  passwordHash       String     @map("password_hash")
  role               UserRole
  status             UserStatus @default(ACTIVE)
  emailVerifiedAt    DateTime?  @map("email_verified_at") @db.Timestamptz
  phoneVerifiedAt    DateTime?  @map("phone_verified_at") @db.Timestamptz
  isKycVerified      Boolean    @default(false) @map("is_kyc_verified")
  locale             String     @default("fr") @db.Char(2)
  lastLoginAt        DateTime?  @map("last_login_at") @db.Timestamptz
  lastLoginIp        String?    @map("last_login_ip") @db.Inet
  failedLoginCount   Int        @default(0) @map("failed_login_count")
  lockedUntil        DateTime?  @map("locked_until") @db.Timestamptz
  referralCode       String     @unique @map("referral_code") @db.VarChar(12)
  referredById       String?    @map("referred_by_id") @db.Uuid
  marketingConsent   Boolean    @default(false) @map("marketing_consent")
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?  @map("deleted_at") @db.Timestamptz

  referredBy         User?      @relation("Referrals", fields: [referredById], references: [id])
  referrals          User[]     @relation("Referrals")

  profile            UserProfile?
  sessions           UserSession[]
  twoFactor          TwoFactorSecret?
  otpCodes           OtpCode[]
  passwordResets     PasswordReset[]
  oauthAccounts      OAuthAccount[]
  kycVerifications   KycVerification[]
  kycReviewed        KycVerification[] @relation("KycReviewedBy")
  addresses          Address[]
  shop               Shop?
  deliveryProfile    DeliveryProfile?
  subscriptions      Subscription[]
  subscriptionsGranted Subscription[] @relation("SubscriptionGrantedBy")
  ordersPlaced       Order[]
  negotiations       PriceNegotiation[]
  deliveriesDone     Delivery[]        @relation("DeliveryDriver")
  wallet             Wallet?
  withdrawalsApproved WithdrawalRequest[] @relation("WithdrawalApprovedBy")
  couponRedemptions  CouponRedemption[]
  auctionsWon        Auction[]         @relation("AuctionWinner")
  auctionLeading     Auction[]         @relation("AuctionLeader")
  auctionBids        AuctionBid[]
  storyViews         StoryView[]
  reviewsAuthored    Review[]
  disputesOpened     Dispute[]         @relation("DisputeOpenedBy")
  disputesAgainst    Dispute[]         @relation("DisputeAgainst")
  disputesResolved   Dispute[]         @relation("DisputeResolvedBy")
  disputeMessages    DisputeMessage[]
  familyInvitesSent  FamilyBadgeInvitation[] @relation("FamilyInviter")
  familyInvitesRcvd  FamilyBadgeInvitation[] @relation("FamilyInvitee")
  points             UserPoints?
  pointsTx           PointsTransaction[]
  badges             UserBadge[]
  jobApplications    JobApplication[]
  legalAcceptances   UserLegalAcceptance[]
  notifications      Notification[]
  pushTokens         PushToken[]
  conversationsAssigned Conversation[] @relation("ConversationAssigned")
  auditLogs          AuditLog[]
  kycAuditTrail      KycAuditTrail[]
  settingsUpdated    SiteSetting[]
  shopAffiliations   ShopDeliveryAffiliation[]

  @@index([email], map: "idx_users_email")
  @@index([phoneE164], map: "idx_users_phone")
  @@index([role, status], map: "idx_users_role_status")
  @@index([referralCode], map: "idx_users_ref_code")
  @@map("users")
}

model UserProfile {
  id           String    @id @default(uuid(7)) @db.Uuid
  userId       String    @unique @map("user_id") @db.Uuid
  firstName    String?   @map("first_name") @db.VarChar(80)
  lastName     String?   @map("last_name") @db.VarChar(80)
  displayName  String?   @map("display_name") @db.VarChar(120)
  avatarUrl    String?   @map("avatar_url")
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  gender       Gender?
  bio          String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserSession {
  id                 String    @id @default(uuid(7)) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  refreshTokenHash   String    @map("refresh_token_hash")
  deviceId           String?   @map("device_id") @db.VarChar(64)
  deviceName         String?   @map("device_name") @db.VarChar(120)
  platform           String?   @db.VarChar(20)
  ip                 String?   @db.Inet
  userAgent          String?   @map("user_agent")
  expiresAt          DateTime  @map("expires_at") @db.Timestamptz
  revokedAt          DateTime? @map("revoked_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([refreshTokenHash])
  @@map("user_sessions")
}

model TwoFactorSecret {
  id                  String    @id @default(uuid(7)) @db.Uuid
  userId              String    @unique @map("user_id") @db.Uuid
  secretEncrypted     Bytes     @map("secret_encrypted")
  enabledAt           DateTime? @map("enabled_at") @db.Timestamptz
  recoveryCodesHash   String[]  @map("recovery_codes_hash")
  lastUsedAt          DateTime? @map("last_used_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_secrets")
}

model OtpCode {
  id          String     @id @default(uuid(7)) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  purpose     OtpPurpose
  codeHash    String     @map("code_hash")
  channel     OtpChannel
  expiresAt   DateTime   @map("expires_at") @db.Timestamptz
  consumedAt  DateTime?  @map("consumed_at") @db.Timestamptz
  attempts    Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
  @@map("otp_codes")
}

model PasswordReset {
  id          String    @id @default(uuid(7)) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  usedAt      DateTime? @map("used_at") @db.Timestamptz
  ip          String?   @db.Inet
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model OAuthAccount {
  id                  String        @id @default(uuid(7)) @db.Uuid
  userId              String        @map("user_id") @db.Uuid
  provider            OAuthProvider
  providerUserId      String        @map("provider_user_id") @db.VarChar(255)
  email               String?       @db.Citext
  accessTokenEnc      Bytes?        @map("access_token_enc")
  refreshTokenEnc     Bytes?        @map("refresh_token_enc")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("oauth_accounts")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 2 — KYC
// ═══════════════════════════════════════════════════════════════════

model KycVerification {
  id                  String          @id @default(uuid(7)) @db.Uuid
  userId              String          @map("user_id") @db.Uuid
  idType              IdDocumentType  @map("id_type")
  idNumberEncrypted   Bytes?          @map("id_number_encrypted")
  documentFrontUrl    String          @map("document_front_url")
  documentBackUrl     String?         @map("document_back_url")
  selfieUrl           String          @map("selfie_url")
  livenessScore       Decimal?        @map("liveness_score") @db.Decimal(5, 4)
  matchScore          Decimal?        @map("match_score") @db.Decimal(5, 4)
  status              KycStatus       @default(PENDING)
  provider            String          @db.VarChar(40)
  providerRef         String?         @map("provider_ref") @db.VarChar(120)
  rawResponse         Json?           @map("raw_response")
  reviewedById        String?         @map("reviewed_by_id") @db.Uuid
  reviewedAt          DateTime?       @map("reviewed_at") @db.Timestamptz
  rejectionReason     String?         @map("rejection_reason")
  expiresAt           DateTime?       @map("expires_at") @db.Date
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy          User?           @relation("KycReviewedBy", fields: [reviewedById], references: [id])
  trail               KycAuditTrail[]

  @@index([userId, status])
  @@index([status])
  @@map("kyc_verifications")
}

model KycAuditTrail {
  id        String          @id @default(uuid(7)) @db.Uuid
  kycId     String          @map("kyc_id") @db.Uuid
  action    String          @db.VarChar(40)
  actorId   String?         @map("actor_id") @db.Uuid
  notes     String?
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz

  kyc       KycVerification @relation(fields: [kycId], references: [id], onDelete: Cascade)
  actor     User?           @relation(fields: [actorId], references: [id])

  @@index([kycId, createdAt])
  @@map("kyc_audit_trail")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 3 — ADRESSES
// ═══════════════════════════════════════════════════════════════════

model Address {
  id             String   @id @default(uuid(7)) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  label          String?  @db.VarChar(60)
  recipientName  String?  @map("recipient_name") @db.VarChar(160)
  phoneE164      String?  @map("phone_e164") @db.VarChar(16)
  country        String   @default("CM") @db.Char(2)
  region         String?  @db.VarChar(80)
  city           String?  @db.VarChar(80)
  neighborhood   String?  @db.VarChar(120)
  street         String?  @db.VarChar(240)
  landmark       String?
  // PostGIS : GEOGRAPHY(Point, 4326) — utilisé via $queryRaw
  geom           Unsupported("geography(Point, 4326)")?
  isDefault      Boolean  @default(false) @map("is_default")
  isPickup       Boolean  @default(false) @map("is_pickup")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  shopPickups      Shop[]    @relation("ShopPickupAddress")
  deliveriesPickup Delivery[] @relation("DeliveryPickup")
  deliveriesDropoff Delivery[] @relation("DeliveryDropoff")
  ordersShipping   Order[]   @relation("OrderShippingAddr")
  ordersBilling    Order[]   @relation("OrderBillingAddr")

  @@index([userId, isDefault])
  @@map("addresses")
}

// ═══════════════════════════════════════════════════════════════════
// DOMAINE 4 — VENDEURS
// ═══════════════════════════════════════════════════════════════════

model Shop {
  id                   String     @id @default(uuid(7)) @db.Uuid
  vendorId             String     @unique @map("vendor_id") @db.Uuid
  slug                 String     @unique @db.VarChar(80)
  name                 String     @db.VarChar(160)
  tagline              String?    @db.VarChar(240)
  description          String?
  logoUrl              String?    @map("logo_url")
  coverUrl             String?    @map("cover_url")
  pickupAddressId      String?    @map("pickup_address_id") @db.Uuid
  region               String?    @db.VarChar(80)
  status               ShopStatus @default(DRAFT)
  ratingAvg            Decimal    @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount          Int        @default(0) @map("rating_count")
  totalSalesXaf        BigInt     @default(0) @map("total_sales_xaf")
  totalOrders          Int        @default(0) @map("total_orders")
  commissionRateBps    Int        @default(500) @map("commission_rate_bps")
  badge                ShopBadge  @default(NONE)
  followersCount       Int        @default(0) @map("followers_count")
  searchVector         Unsupported("tsvector")?  @map("search_vector")
  createdAt            DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt            DateTime?  @map("deleted_at") @db.Timestamptz

  vendor               User       @relation(fields: [vendorId], references: [id])
  pickupAddress        Address?   @relation("ShopPickupAddress", fields: [pickupAddressId], references: [id])

  products             Product[]
  flashSales           FlashSale[]
  coupons              Coupon[]
  auctions             Auction[]
  liveSessions         LiveSession[]
  stories              Story[]
  jobOffers            JobOffer[]
  deliveries           Delivery[]
  affiliations         ShopDeliveryAffiliation[]
  orderItems           OrderItem[]
  escrowHolds          EscrowHold[]   @relation("ShopEscrow")
  negotiations         PriceNegotiation[]

  @@index([slug])
  @@index([region, status])
  @@index([status])
  @@map("shops")
}

model SubscriptionPlan {
  id                String    @id @default(uuid(7)) @db.Uuid
  slug              String    @unique @db.VarChar(40)
  roleTarget        UserRole  @map("role_target")
  name              String    @db.VarChar(80)
  description       String?
  priceMonthlyXaf   BigInt    @default(0) @map("price_monthly_xaf")
  priceYearlyXaf    BigInt?   @map("price_yearly_xaf")
  trialDays         Int       @default(0) @map("trial_days")
  features          Json      @default("{}")
  displayOrder      Int       @default(0) @map("display_order")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  subscriptions     Subscription[]

  @@index([roleTarget, isActive, displayOrder])
  @@map("subscription_plans")
}

model Subscription {
  id                  String              @id @default(uuid(7)) @db.Uuid
  userId              String              @map("user_id") @db.Uuid
  planId              String              @map("plan_id") @db.Uuid
  period              SubscriptionPeriod
  status              SubscriptionStatus
  amountPaidXaf       BigInt?             @map("amount_paid_xaf")
  startedAt           DateTime            @map("started_at") @db.Timestamptz
  currentPeriodEnd    DateTime            @map("current_period_end") @db.Timestamptz
  trialEndsAt         DateTime?           @map("trial_ends_at") @db.Timestamptz
  cancelledAt         DateTime?           @map("cancelled_at") @db.Timestamptz
  autoRenew           Boolean             @default(true) @map("auto_renew")
