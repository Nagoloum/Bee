{
  "expo": {
    "name": "Bee",
    "slug": "bee-marketplace",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "bee",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F59E0B"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cm.bee.marketplace",
      "infoPlist": {
        "NSCameraUsageDescription": "Bee utilise la caméra pour scanner les pièces d'identité et photographier les produits.",
        "NSLocationWhenInUseUsageDescription": "Bee utilise votre position pour les livraisons.",
        "NSFaceIDUsageDescription": "Pour sécuriser vos paiements."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F59E0B"
      },
      "package": "cm.bee.marketplace",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "USE_BIOMETRIC"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      "expo-camera",
      "expo-notifications",
      "expo-local-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
